# ===== 生成物 =====
generated/**

# ===== サンプル Job 用ローカル入力（temp_align 等） =====
samples/source/temp_align/*
!samples/source/temp_align/
!samples/source/temp_align/README.md

# ===== カタログ素材（fetch 後の SVG/PNG — Git 管理外） =====
samples/source/catalog/*
!samples/source/catalog/
!samples/source/catalog/README.md
assets/catalog/*.svg
assets/catalog/*.png
assets/catalog/*-LICENSE
assets/catalog/NOTICES.md

# ===== runtime（設置・バイナリ・重み — Git 管理外） =====
runtime/**
!runtime/README.md

# ===== ローカルビルド =====
dist/
build/
*.spec
*.exe

# ===== レガシー資産（runtime/assets へ移行） =====
assets/fonts/*.ttf
!assets/fonts/DejaVuSans.ttf
!assets/fonts/PixelMplus12-Regular.ttf
assets/fonts/*.otf
assets/fonts/*.ttc
assets/fonts/*-LICENSE
assets/fonts/NOTICES.md

# ===== rulesync 生成物 =====
# 正本は rulesync.jsonc と .rulesync/ に置き、各ツール向け生成物は除外する
.claude/
.cursor/
.codex/
.kilo/
.agents/
AGENTS.md
CLAUDE.md

# ===== ワークスペース（ローカル作業ファイル） =====
# ディレクトリ構造（.gitkeep）は残し、中身のファイルだけ除外する
_workingspace/**
!_workingspace/**/
!_workingspace/**/.gitkeep
_backup/
_old/

# ===== Python =====
__pycache__/
*.pyc
*.pyo
.venv/
.pytest_cache/
*.egg-info/

# ===== Node.js =====
node_modules/

# ===== 環境変数 =====
.env
.env.local

# ===== user-locale（プロジェクト local 上書き） =====
.dna-kernel.local.toml

# ===== OS =====
.DS_Store
Thumbs.db
